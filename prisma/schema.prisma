generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Participant {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  googleId  String    @unique
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  bookings Booking[]
  payments Payment[]
}

enum Role {
  ADMIN
  STAFF
  MANAGER
}

model Event {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  venue              String
  bookingDeadline    DateTime
  capacity           Int
  isOpen             Boolean  @default(true)
  image              String?
  genres             String[]
  baseTicketPrice    Int
  hasDiscount        Boolean
  discountPercentage Int
  discountUpto       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artistId String?
  artist   Artist? @relation(fields: [artistId], references: [id])

  tickets  Ticket[]
  bookings Booking[]
  payments Payment[]
}

model Artist {
  id                String   @id @default(cuid())
  artistName        String
  artistImage       String
  artistBand        String
  artistDescription String
  artistGenere      String[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  events Event[]
  musics Music[]
}

model Music {
  id         String @id @default(cuid())
  musicTitle String

  artistId String
  artist   Artist        @relation(fields: [artistId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Payment {
  id String @id @default(cuid())

  totalAmount        Int
  discountAmount     Int
  discountPercentage Int
  finalAmount        Int

  paymentInitiatorId String
  paymentInitiator   Participant @relation(fields: [paymentInitiatorId], references: [id])

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  paymentStatus PaymentStatus @default(PENDING)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

enum PaymentStatus {
  PAID
  REFUND
  PENDING
  REJECTED
}

model Booking {
  id String @id @default(cuid())

  quantity Int
  status   bookingStatus @default(PENDING)

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id])

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets   Ticket[]
}

enum bookingStatus {
  PAID
  REFUND
  PENDING
  REJECTED
}

model Ticket {
  id    String @id @default(cuid())
  token String @unique @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  attendeeName    String?
  attendeeEmail   String?
  distributorName String?

  category  TicketCategory @default(GENERAL)
  status    TicketStatus   @default(UNUSED)
  source    TicketSource   @default(ADMIN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  checkIn CheckIn?
}

enum TicketCategory {
  GENERAL
  VIP
}

enum TicketStatus {
  UNUSED
  USED
  CANCELLED
}

enum TicketSource {
  ADMIN
  SELF_REGISTERED
}

model CheckIn {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  scannedAt DateTime @default(now())
  createdAt DateTime @default(now())
}
