generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Participant {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  googleId  String    @unique
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

enum Role {
  ADMIN
  STAFF
  MANAGER
}

model Event {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  venue              String
  date               DateTime
  capacity           Int
  isOpen             Boolean  @default(true)
  image              String?
  genres             String[]
  baseTicketPrice    Int
  hasDiscount        Boolean
  discountPercentage Int
  discountUpto       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artistId String?
  artist   Artist? @relation(fields: [artistId], references: [id])

  tickets Ticket[]
}

model Artist {
  id                String   @id @default(cuid())
  artistName        String
  artistImage       String
  artistBand        String
  artistDescription String
  artistGenere      String[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  events Event[]
  musics Music[]
}

model Music {
  id         String @id @default(cuid())
  musicTitle String

  artistId String
  artist   Artist @relation(fields: [artistId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Ticket {
  id              String         @id @default(cuid())
  token           String         @unique @default(cuid())
  eventId         String
  event           Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendeeName    String?
  attendeeEmail   String?
  distributorName String?
  category        TicketCategory @default(GENERAL)
  status          TicketStatus   @default(UNUSED)
  source          TicketSource   @default(ADMIN)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  checkIn         CheckIn?
}

enum TicketCategory {
  GENERAL
  VIP
}

enum TicketStatus {
  UNUSED
  USED
  CANCELLED
}

enum TicketSource {
  ADMIN
  SELF_REGISTERED
}

model CheckIn {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  scannedAt DateTime @default(now())
  createdAt DateTime @default(now())
}
